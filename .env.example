# Copie para .env e ajuste os valores. NÃO commite o .env real.

# Porta do servidor Express.
PORT=3001

# Segredo usado para assinar os JWT. Troque por algo longo e aleatório!
# Ex.: gere com  ->  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-longo

# Credenciais do admin criado no primeiro boot (seed).
ADMIN_NAME=Admin HALLOW
ADMIN_EMAIL=admin@hallow.gg
ADMIN_PASSWORD=admin123
